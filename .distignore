# Files and directories excluded from the production deploy archive.
# Used by `tar --exclude-from` in .github/workflows/deploy.yml. Syntax is
# glob-style; the file is also compatible with rsync's --exclude-from.

# VCS / CI
.git/
.github/
.gitignore
.distignore

# Local dev environment
.docker/
.DS_Store
.husky/
tmp/

# Source files (built output lives in assets/)
src/
tests/

# Build toolchain configs
.browrserlistrc
.eslintrc
.node-version
.stylelintrc.json
gulpfile.js
package.json
package-lock.json
node_modules/

# PHP lint / analysis configs
composer.json
composer.lock
phpcs.ruleset.xml
phpstan.neon
phpstan-baseline.neon

# Generated dep manifests (PHP enqueues hardcode handles currently)
wp-dependencies.json
