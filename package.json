{
  "name": "capitalp",
  "version": "1.0.0",
  "description": "A WordPress theme for Capital P",
  "scripts": {
    "package": "npm run build:css && npm run build:js && npm run build:img && npm run dump",
    "build:css": "sass ./src/scss/:./assets/css/ --style=compressed --no-source-map && postcss ./assets/css/**/*.css --use autoprefixer --replace --no-map",
    "build:js": "grab-deps js src/js assets/js",
    "build:img": "mkdir -p assets/img && cp -R src/img/. assets/img/",
    "dump": "grab-deps dump assets",
    "watch": "npm-watch",
    "lint": "npm run lint:css && npm run lint:js",
    "lint:css": "wp-scripts lint-style './src/scss/**/*.scss'",
    "lint:js": "wp-scripts lint-js ./src/js",
    "fix": "npm run fix:js && npm run fix:css",
    "fix:js": "eslint --fix ./src/js",
    "fix:css": "stylelint --fix ./src/scss",
    "i18n": "po2json languages/ja.po languages/capitalp-ja-capitalp-login.json -f jed",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.js": "wp-scripts lint-js",
    "src/**/*.scss": "wp-scripts lint-style",
    "**/*.php": "vendor/bin/phpcs --standard=phpcs.ruleset.xml --runtime-set ignore_warnings_on_exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fumikito/capitalp.git"
  },
  "keywords": [
    "wordpress"
  ],
  "author": "fumikito <guy@hametuha.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/fumikito/capitalp/issues"
  },
  "homepage": "https://github.com/fumikito/capitalp#readme",
  "engines": {
    "node": ">=18.0"
  },
  "devDependencies": {
    "@kunoichi/grab-deps": "^3.0.0",
    "@wordpress/scripts": "^30.0.0",
    "autoprefixer": "^10.4.16",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-watch": "^0.13.0",
    "po2json": "^1.0.0-alpha",
    "postcss": "^8.4.33",
    "postcss-cli": "^11.0.0",
    "sass": "^1.69.7"
  },
  "watch": {
    "build:js": {
      "extensions": "js,jsx",
      "patterns": [
        "src/js"
      ]
    },
    "build:css": {
      "extensions": "scss",
      "patterns": [
        "src/scss"
      ]
    },
    "build:img": {
      "extensions": "png,jpg,jpeg,gif,svg,webp",
      "patterns": [
        "src/img"
      ]
    },
    "dump": {
      "extensions": "js,css",
      "patterns": [
        "assets/js",
        "assets/css"
      ]
    }
  }
}
